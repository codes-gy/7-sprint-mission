{
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./build",

    // Environment Settings
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "./src/types",
      "./node_modules/@types",
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  }
}